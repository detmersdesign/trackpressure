{
  "expo": {
    "name": "TrackPressures",
    "slug": "trackpressure",
    "version": "1.2.6",
    "scheme": "trackpressure",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0F0F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.detmersdesign.trackpressure",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "TrackPressures uses your location to detect nearby tracks and fetch current weather conditions.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F0F0F"
      },
      "package": "com.detmersdesign.trackpressure",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "TrackPressures uses your location to detect nearby tracks and fetch current weather conditions."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "188ed16a-65e2-44dd-8337-c1afac3c4299"
      }
    }
  }
}
